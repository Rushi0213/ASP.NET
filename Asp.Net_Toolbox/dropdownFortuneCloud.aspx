<%@ Page Language="C#" AutoEventWireup="true" CodeBehind="dropdownFortuneCloud.aspx.cs" Inherits="WebApplication2.dropdownFortuneCloud" %>

<!DOCTYPE html>

<html xmlns="http://www.w3.org/1999/xhtml">
<head runat="server">
    <title>Fortune cloud course form</title>

    <style>
        .full
        {
            text-align:center;
            border:solid;
            margin: 100px 400px 100px 400px;
            padding: 40px 0px 20px 0px;
        }
      .full
      {
          background-image:url("data:image/jpeg;base64,");
      background-repeat:no-repeat;
      background-size:cover;
      height:500px;
      width:600px;
      
          }
      #DropDownList1
      {
          color:rosybrown;
      }
      #Label3
      {
          color:chocolate;
      }
      #Label1{
          background-color:purple;
          color:white;
      }

    .half{
        background-image:url("data:image/jpeg;base64,");
        background-repeat:no-repeat;
        background-size:cover;
       
        }
    legend:hover
    {
     color:darkred;  
    }
  
    </style>
</head>
<body>
    <form id="form1" runat="server">
        <fieldset class=" half">
            <legend> <h2>Fortune Cloud Course Form</h2></legend>
        <div class="full">
       
        <asp:Label ID="Label1" runat="server" Text="FORTUNE CLOUD"></asp:Label>
        <p>
            <asp:Label ID="Label2" runat="server" Text="Select Course : "></asp:Label>
        </p>
 
    
    <p>
            <asp:DropDownList ID="DropDownList1" runat="server" OnSelectedIndexChanged="DropDownList1_SelectedIndexChanged" AutoPostBack="True">
               <asp:ListItem> </asp:ListItem>
                <asp:ListItem>JAVA DEVELOPER</asp:ListItem>
                <asp:ListItem>.NET DEVELOPER</asp:ListItem>
                <asp:ListItem>PYTHON DEVELOPER</asp:ListItem>
                <asp:ListItem>MERN STACK DEVELOPER</asp:ListItem>
                <asp:ListItem>DEVOPS ENGINER</asp:ListItem>
                <asp:ListItem>CYBER SECURITY</asp:ListItem>
                <asp:ListItem>TESTING</asp:ListItem>
            </asp:DropDownList><br /><br />
            <asp:Label ID="Label3" runat="server"></asp:Label>
            </p>
    </div>
            
            </fieldset>
        </form>
</body>
</html>
