            width:1280px;
            border-style:groove;
            border-color:aqua;
          

        }
        #links
        {
            height:50px;
            width:1297px;
            border:dotted;
            text-align:center;
            padding-top:20px;
            background-color:gainsboro;
           


        }
        #content
        {
            border:groove;
            height:1300px;
            width:1278px;
            margin-left:10px;
           margin-top:10px;
            

        }

    </style>
</head>
<body>
    <form id="form1" runat="server">
       
        <div id="main">
            <div id=" header">
                <center>
                <img  src="data:image/png;base64," height="100px" width="950px" />
                    </center>
